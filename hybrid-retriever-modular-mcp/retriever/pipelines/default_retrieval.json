{
  "metadata": {},
  "max_runs_per_component": 100,
  "components": {
    "fts5": {
      "type": "retriever.components.fts5_retriever.Fts5Retriever",
      "init_parameters": {
        "data_root": "C:\\Retriever_Data"
      }
    },
    "joiner": {
      "type": "retriever.components.hybrid_joiner.HybridJoiner",
      "init_parameters": {}
    },
    "parent": {
      "type": "retriever.components.parent_replace.ParentChunkReplacer",
      "init_parameters": {}
    },
    "query_embedder": {
      "type": "retriever.components.document_embedder.HttpTextEmbedder",
      "init_parameters": {
        "api_url": "",
        "api_key": "",
        "model": "",
        "dim": 0,
        "x_dep_ticket": "",
        "x_system_name": "hybrid-retriever-modular-mcp",
        "batch_size": 16,
        "timeout_sec": 60,
        "verify_ssl": false
      }
    },
    "vector": {
      "type": "retriever.components.vector_retriever.LocalQdrantRetriever",
      "init_parameters": {
        "data_root": "",
        "collection": "retriever_chunks"
      }
    }
  },
  "connections": [
    {
      "sender": "fts5.documents",
      "receiver": "joiner.keyword_documents"
    },
    {
      "sender": "joiner.documents",
      "receiver": "parent.documents"
    },
    {
      "sender": "query_embedder.embedding",
      "receiver": "vector.embedding"
    },
    {
      "sender": "vector.documents",
      "receiver": "joiner.semantic_documents"
    }
  ],
  "connection_type_validation": true
}