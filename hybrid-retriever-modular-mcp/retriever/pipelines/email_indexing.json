{
  "metadata": {},
  "max_runs_per_component": 100,
  "components": {
    "converter": {
      "type": "retriever.components.email_markdown_converter.EmailMarkdownConverter",
      "init_parameters": {
        "max_body_chars": 1000000,
        "max_attachment_chars": 500000
      }
    },
    "embedder": {
      "type": "retriever.components.document_embedder.HttpDocumentEmbedder",
      "init_parameters": {
        "api_url": "",
        "api_key": "",
        "model": "",
        "dim": 0,
        "x_dep_ticket": "",
        "x_system_name": "hybrid-retriever-modular-mcp",
        "batch_size": 16,
        "timeout_sec": 60,
        "verify_ssl": false
      }
    },
    "loader": {
      "type": "retriever.components.email_loader.EmailSourceLoader",
      "init_parameters": {
        "worker_path": "C:\\Users\\joung\\_work_slsi\\hybrid-retriever-modular-mcp\\retriever\\scripts\\pst_worker.py"
      }
    },
    "qdrant_writer": {
      "type": "retriever.components.vector_retriever.LocalQdrantWriter",
      "init_parameters": {
        "data_root": "C:\\Retriever_Data",
        "collection": "retriever_chunks"
      }
    },
    "splitter": {
      "type": "retriever.components.hierarchical_splitter.HierarchicalSplitter",
      "init_parameters": {
        "chunk_chars": 512,
        "chunk_overlap": 50,
        "parent_chunk_chars": 1024,
        "parent_chunk_overlap": 100,
        "child_chunk_chars": 256,
        "child_chunk_overlap": 50
      }
    }
  },
  "connections": [
    {
      "sender": "converter.documents",
      "receiver": "splitter.documents"
    },
    {
      "sender": "embedder.documents",
      "receiver": "qdrant_writer.documents"
    },
    {
      "sender": "embedder.has_vector",
      "receiver": "qdrant_writer.has_vector"
    },
    {
      "sender": "loader.raw_emails",
      "receiver": "converter.raw_emails"
    },
    {
      "sender": "splitter.documents",
      "receiver": "embedder.documents"
    }
  ],
  "connection_type_validation": true
}