{
  "metadata": {
    "description": "Use when: queries are exact-string / keyword / code-token / identifier lookups, or the embedding endpoint is down, or you want a fast pure-FTS5 baseline. Skips embedding entirely; vector_similarity_weight is forced to 0; fusion is RRF."
  },
  "max_runs_per_component": 100,
  "connection_type_validation": true,
  "nodes": [
    {
      "name": "loader",
      "module": "retriever.components.file_loader.LocalFileLoader",
      "params": {
        "max_chars": 2000000
      }
    },
    {
      "name": "splitter",
      "module": "retriever.components.hierarchical_splitter.HierarchicalSplitter",
      "params": {
        "chunk_chars": 512,
        "chunk_overlap": 50,
        "parent_chunk_chars": 1024,
        "parent_chunk_overlap": 100,
        "child_chunk_chars": 256,
        "child_chunk_overlap": 50
      },
      "inputs": [
        {
          "port": "text",
          "from": "loader.text"
        }
      ]
    },
    {
      "name": "writer",
      "module": "retriever.components.fts5_writer.SqliteFts5Writer",
      "params": {
        "data_root": "${RETRIEVER_DATA_ROOT}"
      },
      "inputs": [
        {
          "port": "documents",
          "from": "splitter.documents"
        }
      ]
    },
    {
      "name": "fts5",
      "module": "retriever.components.fts5_retriever.Fts5Retriever",
      "params": {
        "data_root": "${RETRIEVER_DATA_ROOT}"
      }
    },
    {
      "name": "joiner",
      "module": "retriever.components.rrf_joiner.RrfJoiner",
      "params": {},
      "inputs": [
        {
          "port": "keyword_documents",
          "from": "fts5.documents"
        }
      ]
    },
    {
      "name": "parent",
      "module": "retriever.components.parent_replace.ParentChunkReplacer",
      "params": {},
      "inputs": [
        {
          "port": "documents",
          "from": "joiner.documents"
        }
      ],
      "answer_template": "키워드 매칭 결과만 있으므로 의미 추론으로 빈칸을 메우지 말고 매칭된 표현을 그대로 인용해 답하라. 답이 모호하면 '키워드 매칭된 단서만 있음'을 명시하라. 인용은 [document_name:position]."
    }
  ]
}
