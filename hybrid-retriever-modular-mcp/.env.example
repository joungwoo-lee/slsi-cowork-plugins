# --- Data root --------------------------------------------------------------
# Where the local SQLite/Qdrant/Kùzu state lives.
# If unset, defaults to .retriever_data/ inside the project root.
RETRIEVER_DATA_ROOT=

# Comma-separated dataset IDs used when an MCP `search` call omits dataset_ids.
RETRIEVER_DEFAULT_DATASETS=my_docs

# --- Chunking ---------------------------------------------------------------
RETRIEVER_CHUNK_CHARS=512
RETRIEVER_CHUNK_OVERLAP=50
RETRIEVER_MAX_FILE_CHARS=2000000
ENABLE_PARENT_CHILD_CHUNKING=true
PARENT_CHUNK_SIZE=1024
PARENT_CHUNK_OVERLAP=100
CHILD_CHUNK_SIZE=256
CHILD_CHUNK_OVERLAP=50

# --- Search fusion ----------------------------------------------------------
HYBRID_ALPHA=0.5
RETRIEVER_FUSION=linear
RRF_K=60

# --- Embedding (optional) ---------------------------------------------------
# Leave EMBEDDING_API_URL blank to run keyword-only. When configured the
# server adds a Qdrant vector branch and hybrid fusion.
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_X_DEP_TICKET=
EMBEDDING_API_X_SYSTEM_NAME=hybrid-retriever-modular-mcp
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SEC=60
# Keep TRUE against public providers. Only flip to false for internal
# endpoints presenting self-signed certificates.
EMBEDDING_VERIFY_SSL=true

# --- Qdrant -----------------------------------------------------------------
QDRANT_COLLECTION=retriever_chunks
QDRANT_DISTANCE=Cosine

# --- LLM (optional, required for Hippo2 OpenIE / query-entity/filter steps) -
# Wire shape mirrors the embedding client: URL + bearer key + optional
# x-dep-ticket / x-system-name headers + verify_ssl toggle. The expected
# payload is the OpenAI /v1/chat/completions contract; any compatible
# self-hosted gateway (vLLM, internal proxy) works the same way.
#
# If these are left blank but EMBEDDING_API_URL points at OpenAI and
# EMBEDDING_API_KEY is present, the server automatically reuses that key and
# falls back to OpenAI chat completions with OPENAI_LLM_MODEL (default:
# gpt-4o-mini).
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini
LLM_API_X_DEP_TICKET=
LLM_API_X_SYSTEM_NAME=hybrid-retriever-modular-mcp
LLM_BATCH_SIZE=8
LLM_TIMEOUT_SEC=60
LLM_VERIFY_SSL=true
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# --- Hippo2 knobs ---------------------------------------------------------
# synonym_threshold: cosine similarity above which two entity embeddings get
# a SYNONYM edge. 0.85 is conservative; lower it (e.g. 0.78) for noisier
# domains where the same concept gets many surface variants.
HIPPO2_SYNONYM_THRESHOLD=0.85
HIPPO2_SYNONYM_TOP_K=8
HIPPO2_PPR_ALPHA=0.85
HIPPO2_PPR_MAX_ITER=50
HIPPO2_PPR_TOL=1e-6
HIPPO2_QUERY_TOP_ENTITIES=5
HIPPO2_TOP_CHUNKS=12
HIPPO2_EXTRACTION_MAX_TRIPLES=32
HIPPO2_PASSAGE_NODE_WEIGHT=0.05
HIPPO2_ONLINE_FILTER_ENABLED=true
HIPPO2_ONLINE_FILTER_CANDIDATES=24
HIPPO2_ONLINE_FILTER_MIN_KEEP=1
