# ==============================================================================
# email-connector 환경 설정 (.env.example)
# 이 파일을 .env 로 복사한 뒤 실제 환경에 맞게 수정하여 사용하세요.
# 변수명은 retriever_engine 프로젝트와 호환됩니다.
# ==============================================================================

# [PST 소스]
# 인제스트할 PST 파일의 절대경로. ingest/convert 명령은 --pst 인자가 없으면 이 값을 사용합니다.
PST_PATH=C:\Users\me\Documents\archive.pst

# [데이터 저장소]
# 통합 마크다운, 첨부파일, SQLite, Qdrant가 모두 이 경로 아래에 생성됩니다.
DATA_ROOT=C:\Outlook_Data


# [임베딩(Embedding) API 설정]
# OpenAI 호환 엔드포인트. retriever_engine과 동일한 헤더(x-dep-ticket, x-system-name)를 보냅니다.
# ------------------------------------------------------------------------------
EMBEDDING_API_URL=http://localhost:8080/v1/embeddings
EMBEDDING_API_KEY=your_embedding_api_key
# 모델명 (예: BAAI/bge-m3, openai/text-embedding-3-small)
EMBEDDING_MODEL=BAAI/bge-m3
# 모델의 실제 벡터 차원 (bge-m3=1024, text-embedding-3-small=1536, 3-large=3072)
EMBEDDING_DIM=1024
# 사내 인증 헤더 (필요 없으면 비워둠)
EMBEDDING_API_X_DEP_TICKET=your_credential_ticket
EMBEDDING_API_X_SYSTEM_NAME=email-connector
# 배치 크기 / 타임아웃
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SEC=60
# SSL 인증서 검증 — 사내 MITM 프록시 환경 대응 디폴트는 false. 공인 CA endpoint이면 true 권장.
EMBEDDING_VERIFY_SSL=false


# [Qdrant 설정]
# ------------------------------------------------------------------------------
QDRANT_COLLECTION=emails
QDRANT_DISTANCE=Cosine


# [인제스트 한도]
# ------------------------------------------------------------------------------
MAX_BODY_CHARS=200000
MAX_ATTACHMENT_CHARS=200000


# [검색]
# 하이브리드 검색에서 키워드 점수의 가중치 (0.0=의미만, 1.0=키워드만)
HYBRID_ALPHA=0.5


# [프록시 (사내망인 경우만, 직접 인터넷 접근 가능하면 비워둠)]
# python 프로세스(requests, urllib)와 pip 모두에 동일하게 적용되도록 셸 환경변수도 함께 set/setx 하세요.
# NO_PROXY에는 사내 임베딩 endpoint를 반드시 포함시키세요.
# ------------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
